{
  "id": "upper_body_weights",
  "name": "Upper Body Antagonist (Push)",
  "version": "1.0",
  "intent": {
    "primary_goal": "strength_general",
    "secondary_goals": ["joint_health"],
    "notes": "Antagonist upper body — chest, triceps, anterior shoulders. Balances the pull-dominant pattern of climbing. Elbow and shoulder health. Bodyweight or with weights if available."
  },
  "compatibility": {
    "slot": ["short"],
    "sports": ["climbing"]
  },
  "required_equipment": [],
  "context": {
    "location": "home"
  },
