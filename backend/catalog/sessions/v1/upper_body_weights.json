        "primary": {
          "filters": {
            "role": ["accessory"],
            "domain": ["strength_general"],
            "pattern": ["push_vertical", "push_horizontal"]
          }
        }
      }
    },
    {
      "template_id": "cooldown_stretch",
      "required": false,
      "priority": 30,
      "module_role": "cooldown"
    }
  ]
