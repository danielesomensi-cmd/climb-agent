{
  "id": "heavy_conditioning_gym",
  "name": "Heavy Complementary Strength (Gym)",
  "version": "1.0",
  "intent": {
    "primary_goal": "strength_general",
    "secondary_goals": ["core", "joint_health"],
    "notes": "Compound barbell/dumbbell session. Row + Press + Hinge. Builds general strength base."
  },
  "compatibility": {
    "slot": ["long", "short"],
    "sports": ["climbing"]
  },
  "context": {
    "location": "gym"
  },
  "time_budget": {
    "target_duration_min": 50,
    "hard_cap_min": 65
  },
  "modules": [
    {
      "template_id": "warmup_strength",
      "required": true,
      "priority": 100,
      "module_role": "general_warmup"
    },
    {
      "block_id": "compound_pull",
      "required": true,
      "priority": 90,
      "module_role": "primary",
      "notes": "Horizontal pull — barbell or dumbbell row. Heavy: 3-4x5-6 reps.",
      "selection": {
        "primary": {
          "filters": {
            "role": ["accessory"],
            "domain": ["strength_general"],
            "pattern": ["pull_horizontal"]
          }
        }
      }
    },
    {
      "block_id": "compound_push",
      "required": false,
      "priority": 80,
      "module_role": "secondary",
      "notes": "Overhead press or bench. Antagonist push for shoulder balance.",
      "selection": {
        "primary": {
          "filters": {
            "role": ["accessory"],
            "domain": ["strength_general"],
            "pattern": ["push"]
          }
        }
      }
    },
    {
      "block_id": "compound_hinge",
      "required": false,
      "priority": 70,
      "module_role": "secondary",
      "notes": "RDL or loaded carry. Posterior chain and total-body stability.",
      "selection": {
        "primary": {
          "filters": {
            "role": ["accessory"],
            "domain": ["strength_general"],
            "pattern": ["hinge", "carry"]
          }
        }
      }
    },
    {
      "template_id": "core_standard",
      "required": false,
      "priority": 50,
      "module_role": "secondary"
    },
    {
      "template_id": "cooldown_stretch",
      "required": false,
      "priority": 40,
      "module_role": "cooldown"
    }
  ],
  "coach_notes": {
    "warmup_emphasis": "Joint prep: shoulder CARs, cat-cow, hip hinge pattern at bodyweight.",
    "post_session": "Forearm and shoulder stretching. Avoid heavy grip work day before/after finger sessions."
  }
}
