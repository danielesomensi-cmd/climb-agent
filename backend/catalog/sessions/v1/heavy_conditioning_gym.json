{
  "id": "heavy_conditioning_gym",
  "name": "Heavy Conditioning Gym",
  "version": "1.0",
  "intent": {
    "primary_goal": "strength_general",
    "secondary_goals": ["core", "push", "joint_health"],
    "notes": "Compound barbell/dumbbell session. Row + Press + Dip + Hinge + Core compression. Builds general strength base with full push/pull/core coverage."
  },
  "compatibility": {
    "slot": ["long", "short"],
    "sports": ["climbing"]
  },
  "required_equipment": ["dumbbell"],
  "context": {
    "location": "gym"
  },
  "time_budget": {
    "target_duration_min": 50,
    "hard_cap_min": 65
  },
  "modules": [
    {
      "template_id": "warmup_strength",
      "required": true,
      "priority": 100,
      "module_role": "general_warmup"
    },
    {
      "block_id": "compound_pull",
      "required": true,
      "priority": 90,
      "module_role": "primary",
      "notes": "Horizontal pull — barbell or dumbbell row. Heavy: 3-4x5-6 reps.",
      "selection": {
        "primary": {
          "filters": {
            "role": ["accessory"],
            "domain": ["strength_general"],
            "pattern": ["pull_horizontal"]
          }
        }
      }
    },
    {
      "block_id": "compound_push",
      "required": true,
      "priority": 80,
      "module_role": "secondary",
      "notes": "Bench press or dumbbell bench. Chest/push focus. 3x8 reps, rest 90s.",
      "selection": {
        "primary": {
          "filters": {
            "role": ["accessory"],
            "domain": ["strength_general"],
            "pattern": ["push"]
          }
        }
      }
    },
    {
      "block_id": "triceps_dip",
      "required": true,
      "priority": 75,
      "module_role": "secondary",
      "notes": "Dip for triceps and anterior push. 3x10, rest 60s.",
      "selection": {
        "primary": {
          "exercise_id": "dip",
          "prescription_overrides": {
            "sets": 3,
            "reps": 10,
            "rest_between_sets_seconds": 60
          }
        }
      }
    },
    {
      "block_id": "compound_hinge",
      "required": false,
      "priority": 70,
      "module_role": "secondary",
      "notes": "RDL or loaded carry. Posterior chain and total-body stability.",
      "selection": {
        "primary": {
          "filters": {
            "role": ["accessory"],
            "domain": ["strength_general"],
            "pattern": ["hinge", "carry"]
          }
        }
      }
    },
    {
      "block_id": "core_compression",
      "required": true,
      "priority": 55,
      "module_role": "secondary",
      "notes": "Hanging leg raise or ab wheel. Core compression focus. 3x10, rest 60s.",
      "selection": {
        "primary": {
          "exercise_id": "hanging_leg_raise",
          "prescription_overrides": {
            "sets": 3,
            "reps": 10,
            "rest_between_sets_seconds": 60
          }
        }
      }
    },
    {
      "template_id": "core_standard",
      "required": true,
      "priority": 50,
      "module_role": "secondary"
    },
    {
      "template_id": "cooldown_stretch",
      "required": false,
      "priority": 40,
      "module_role": "cooldown"
    }
  ],
  "coach_notes": {
    "warmup_emphasis": "Joint prep: shoulder CARs, cat-cow, hip hinge pattern at bodyweight.",
    "post_session": "Forearm and shoulder stretching. Avoid heavy grip work day before/after finger sessions."
  }
}
