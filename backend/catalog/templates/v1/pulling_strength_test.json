{
  "id": "pulling_strength_test",
  "name": "Pulling Strength (Test Protocol)",
  "version": "1.0",
  "category": "strength",
  "sport": "climbing",

  "stress_tags": {
    "fingers": "low",
    "cns": "medium",
    "elbows": "medium",
    "skin": "none"
  },

  "blocks": [
    {
      "block_id": "main",
      "type": "main_set",
      "exercise_id": "weighted_pullup",
      "prescription": {
        "sets": 5,
        "reps": 1,
        "rest_between_sets_seconds": 240,
        "notes": "1RM test protocol. Pyramid up: set 1 ~50% est. max, set 2 ~70%, set 3 ~85%, set 4 ~95%, set 5 max attempt. Full rest between sets. Stop if form breaks."
      },
      "role": ["main"],
      "domain": ["strength_general"]
    },
    {
      "block_id": "test_l_sit",
      "type": "test_measurement",
      "exercise_id": "test_l_sit_hold",
      "prescription": {
        "sets": 1,
        "notes": "Full L-sit with straight legs. Hold as long as possible. Record total seconds."
      },
      "role": ["test"],
      "domain": ["core"]
    }
  ]
}
